{
  "name": "memory_usefulness_feedback",
  "description": "Ensure memory cards used in orchestration receive post-use feedback that increases version, activation, and confidence.",
  "lane": "regression",
  "tags": [
    "memory",
    "chat",
    "feedback",
    "procedural",
    "recall"
  ],
  "steps": [
    {
      "id": "seed_active_web_fact",
      "type": "seed_memory_card",
      "metadata": {
        "card_id": "web:activation-guided-recall",
        "card_type": "web_result",
        "scope": "project",
        "status": "active",
        "source": "harness",
        "confidence": "0.70",
        "activation_score": "0.45",
        "activation_decay_policy": "session_use",
        "content.title": "Activation-guided recall",
        "content.snippet": "Cue-based activation recall keeps memory orchestration bounded instead of brute-force retrieval."
      }
    },
    {
      "id": "seed_active_procedure",
      "type": "seed_memory_card",
      "metadata": {
        "card_id": "procedure:expense_audit:feedback-v1",
        "card_type": "procedure",
        "scope": "project",
        "status": "active",
        "source": "harness",
        "confidence": "0.80",
        "activation_score": "0.30",
        "activation_decay_policy": "session_use",
        "content.name": "expense_audit_feedback_v1",
        "content.task_class": "expense_audit",
        "content.summary": "For expense audit planning, validate policy before generating final recommendations.",
        "content.steps": "extract_fields\nvalidate_policy\nflag_missing_evidence"
      }
    },
    {
      "id": "ask_plan",
      "type": "send_chat",
      "session_id": "default",
      "message": "帮我规划一个 expense audit 工作流，要求使用 cue-based activation recall，并且先 validate policy。"
    }
  ],
  "assertions": [
    {
      "type": "selected_skill",
      "step": "ask_plan",
      "equals": "task-plan"
    },
    {
      "type": "task_state",
      "step": "ask_plan",
      "equals": "done"
    },
    {
      "type": "durable_card_version_at_least",
      "field": "web_result",
      "contains": "bounded instead of brute-force retrieval",
      "min": 2
    },
    {
      "type": "durable_card_activation_score_range",
      "field": "web_result",
      "contains": "bounded instead of brute-force retrieval",
      "min_confidence": 0.50,
      "max_confidence": 0.60
    },
    {
      "type": "durable_card_confidence_range",
      "field": "web_result",
      "contains": "bounded instead of brute-force retrieval",
      "min_confidence": 0.71,
      "max_confidence": 0.75
    },
    {
      "type": "durable_card_version_at_least",
      "field": "procedure",
      "contains": "expense_audit_feedback_v1",
      "min": 2
    },
    {
      "type": "durable_card_activation_score_range",
      "field": "procedure",
      "contains": "expense_audit_feedback_v1",
      "min_confidence": 0.40,
      "max_confidence": 0.50
    },
    {
      "type": "durable_card_confidence_range",
      "field": "procedure",
      "contains": "expense_audit_feedback_v1",
      "min_confidence": 0.83,
      "max_confidence": 0.86
    }
  ]
}
