{
  "name": "web_search_summary",
  "description": "Run a fixture-backed web search task and assert artifact output.",
  "tags": [
    "web",
    "memory",
    "connector"
  ],
  "fixtures": {
    "search_response_file": "fixtures/search_response.json"
  },
  "steps": [
    {
      "id": "submit_search",
      "type": "submit_task",
      "title": "Search OpenClaw memory design",
      "goal": "Search the web for OpenClaw memory design",
      "selected_skill": "web-search",
      "metadata": {
        "query": "OpenClaw memory design"
      }
    },
    {
      "id": "run_search",
      "type": "run_task",
      "task_ref": "submit_search"
    }
  ],
  "assertions": [
    {
      "type": "task_state",
      "step": "run_search",
      "equals": "done"
    },
    {
      "type": "selected_skill",
      "step": "run_search",
      "equals": "web-search"
    },
    {
      "type": "artifact_count",
      "step": "run_search",
      "min": 1
    },
    {
      "type": "artifact_contains",
      "step": "run_search",
      "contains": "OpenClaw"
    },
    {
      "type": "artifact_contains",
      "step": "run_search",
      "contains": "hybrid retrieval"
    }
  ],
  "lane": "smoke"
}
