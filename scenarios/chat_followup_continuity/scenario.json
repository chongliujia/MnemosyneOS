{
  "name": "chat_followup_continuity",
  "description": "Ensure a chat follow-up continues the prior search thread instead of drifting.",
  "tags": [
    "chat",
    "memory",
    "connector"
  ],
  "fixtures": {
    "search_response_file": "fixtures/search_response.json"
  },
  "steps": [
    {
      "id": "ask_search",
      "type": "send_chat",
      "session_id": "default",
      "message": "帮我搜索一下 OpenClaw 的 memory 设计"
    },
    {
      "id": "followup_expand",
      "type": "send_chat",
      "session_id": "default",
      "message": "继续展开"
    }
  ],
  "assertions": [
    {
      "type": "selected_skill",
      "step": "ask_search",
      "equals": "web-search"
    },
    {
      "type": "task_state",
      "step": "ask_search",
      "equals": "done"
    },
    {
      "type": "assistant_contains",
      "step": "ask_search",
      "contains": "继续展开这些结果"
    },
    {
      "type": "assistant_contains",
      "step": "followup_expand",
      "contains": "OpenClaw"
    },
    {
      "type": "session_state_contains",
      "session_id": "default",
      "field": "focus_task_id",
      "contains": "task-"
    }
  ],
  "lane": "smoke"
}
