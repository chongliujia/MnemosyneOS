{
  "name": "continue_existing_task_without_new_task",
  "description": "Ensure a follow-up continuation reuses the focused completed task instead of creating a new task.",
  "lane": "regression",
  "tags": [
    "chat",
    "working-memory",
    "ux",
    "followup"
  ],
  "fixtures": {
    "search_response_file": "fixtures/search_response.json"
  },
  "steps": [
    {
      "id": "ask_search",
      "type": "send_chat",
      "session_id": "default",
      "message": "帮我搜索一下 OpenClaw 的 memory 设计"
    },
    {
      "id": "continue_thread",
      "type": "send_chat",
      "session_id": "default",
      "message": "继续展开"
    }
  ],
  "assertions": [
    {
      "type": "selected_skill",
      "step": "ask_search",
      "equals": "web-search"
    },
    {
      "type": "task_state",
      "step": "ask_search",
      "equals": "done"
    },
    {
      "type": "assistant_contains",
      "step": "continue_thread",
      "contains": "OpenClaw"
    },
    {
      "type": "session_state_contains",
      "session_id": "default",
      "field": "focus_task_id",
      "contains": "task-"
    }
  ]
}
