{
  "name": "fact_supersession_lifecycle",
  "description": "Ensure a promoted candidate can supersede an older active fact and archive unused candidates.",
  "lane": "regression",
  "tags": [
    "memory",
    "lifecycle",
    "consolidation",
    "web"
  ],
  "steps": [
    {
      "id": "seed_old_fact",
      "type": "seed_memory_card",
      "metadata": {
        "card_id": "search:openclaw:v1",
        "card_type": "search_summary",
        "scope": "project",
        "status": "active",
        "source": "harness",
        "confidence": "0.7",
        "content.summary": "OpenClaw only uses embedding top-k retrieval."
      }
    },
    {
      "id": "seed_corrected_fact",
      "type": "seed_memory_card",
      "metadata": {
        "card_id": "search:openclaw:v2",
        "card_type": "search_summary",
        "scope": "project",
        "status": "candidate",
        "supersedes": "search:openclaw:v1",
        "source": "harness",
        "confidence": "0.92",
        "content.summary": "OpenClaw uses hybrid retrieval with BM25 and vectors."
      }
    },
    {
      "id": "seed_cold_candidate",
      "type": "seed_memory_card",
      "metadata": {
        "card_id": "search:openclaw:v3",
        "card_type": "search_summary",
        "scope": "project",
        "status": "candidate",
        "source": "harness",
        "confidence": "0.4",
        "content.summary": "cold candidate that should be archived"
      }
    },
    {
      "id": "consolidate_facts",
      "type": "consolidate_memory",
      "metadata": {
        "card_type": "search_summary",
        "scope": "project",
        "limit": "1",
        "archive_remaining": "true"
      }
    }
  ],
  "assertions": [
    {
      "type": "durable_card_status",
      "field": "search_summary",
      "contains": "only uses embedding top-k retrieval",
      "equals": "superseded"
    },
    {
      "type": "durable_card_status",
      "field": "search_summary",
      "contains": "hybrid retrieval with BM25 and vectors",
      "equals": "active"
    },
    {
      "type": "durable_card_supersedes",
      "field": "search_summary",
      "contains": "hybrid retrieval with BM25 and vectors",
      "equals": "search:openclaw:v1"
    },
    {
      "type": "durable_card_status",
      "field": "search_summary",
      "contains": "cold candidate that should be archived",
      "equals": "archived"
    },
    {
      "type": "recall_contains",
      "query": "OpenClaw retrieval",
      "source": "web",
      "contains": "hybrid retrieval with BM25 and vectors"
    },
    {
      "type": "recall_not_contains",
      "query": "OpenClaw retrieval",
      "source": "web",
      "contains": "only uses embedding top-k retrieval"
    }
  ]
}
