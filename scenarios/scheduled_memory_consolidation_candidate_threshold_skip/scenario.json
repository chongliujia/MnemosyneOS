{
  "name": "scheduled_memory_consolidation_candidate_threshold_skip",
  "description": "Scheduler should skip when eligible candidate count is below the configured threshold.",
  "tags": [
    "memory",
    "scheduler"
  ],
  "lane": "regression",
  "steps": [
    {
      "id": "seed_candidate",
      "type": "seed_memory_card",
      "metadata": {
        "card_id": "candidate:web:threshold-1",
        "card_type": "web_result",
        "scope": "project",
        "status": "candidate",
        "source": "web",
        "confidence": "0.70",
        "content.snippet": "candidate below threshold"
      }
    },
    {
      "id": "schedule_memory",
      "type": "schedule_memory_consolidation",
      "metadata": {
        "reason": "task_completion",
        "scope": "project",
        "min_candidates": "2",
        "allowed_card_types": "web_result,procedure"
      }
    }
  ],
  "assertions": [
    {
      "type": "scheduler_triggered",
      "step": "schedule_memory",
      "equals": "false"
    },
    {
      "type": "scheduler_skip_reason",
      "step": "schedule_memory",
      "equals": "candidate_threshold"
    }
  ]
}
