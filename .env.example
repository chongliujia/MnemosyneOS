# These env vars seed runtime/model/config.json on first boot.
# After that, use /ui/models to manage:
# - conversation / routing / skills models
# suggested starting budgets: conversation=1600, routing=220, skills=1200
# - per-profile max tokens
# - temperatures

MNEMOSYNE_MODEL_PROVIDER=deepseek
MNEMOSYNE_MODEL_NAME=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace_me

# Or an OpenAI-compatible chat-completions endpoint:
# MNEMOSYNE_MODEL_PROVIDER=deepseek|siliconflow|openai|openai-compatible
# MNEMOSYNE_MODEL_NAME=gpt-4o-mini
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=replace_me

# Optional web search connector.
MNEMOSYNE_WEB_SEARCH_PROVIDER=none
# MNEMOSYNE_WEB_SEARCH_API_KEY=replace_me
# MNEMOSYNE_WEB_SEARCH_ENDPOINT=https://serpapi.com/search.json

# Optional GitHub connector.
# MNEMOSYNE_GITHUB_OWNER=owner
# MNEMOSYNE_GITHUB_REPO=repo
# MNEMOSYNE_GITHUB_TOKEN=replace_me
# MNEMOSYNE_GITHUB_BASE_URL=https://api.github.com

# Optional email connector.
# MNEMOSYNE_EMAIL_PROVIDER=maildir
# MNEMOSYNE_MAILDIR_ROOT=/path/to/maildir
# MNEMOSYNE_MAILDIR_MAILBOX=INBOX
#
# Or IMAP read-only:
# MNEMOSYNE_EMAIL_PROVIDER=imap
# MNEMOSYNE_IMAP_HOST=imap.example.com
# MNEMOSYNE_IMAP_PORT=993
# MNEMOSYNE_IMAP_USERNAME=agent@example.com
# MNEMOSYNE_IMAP_PASSWORD=replace_me
# MNEMOSYNE_IMAP_MAILBOX=INBOX
# MNEMOSYNE_IMAP_TLS=true

# Optional approval token for root-profile execution in the MVP executor.
# This authorizes root-mode requests at the AgentOS control layer only; it does not
# elevate the process outside the current OS user yet.
MNEMOSYNE_ROOT_APPROVAL_TOKEN=replace_me_for_root_tests

# SiliconFlow
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_API_KEY=your-siliconflow-key
